---
interface Props {
  billede: string;
  navn: string;
}

const { billede, navn } = Astro.props;
---

<div class="polaroid">
  <img src={billede} alt={navn} />
  <p class="navn">{navn}</p>
</div>

<style>
  .polaroid {
    background: white;
    padding: 1rem 1rem 1.5rem 1rem;
    max-width: 320px;
  }

  .polaroid img {
    width: 100%;
    object-fit: cover;
    display: block;
  }

  .navn {
    font-family: "newshound", sans-serif;
    font-size: clamp(1.2rem, 2vw, 1.8rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 1rem 0 0 0.5rem;
  }
</style>
